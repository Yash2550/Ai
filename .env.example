# Copy this file to .env and fill in your API keys.

# Get your Recraft.ai API key from your Recraft developer settings:
RECRAFT_API_KEY=your_recraft_api_key_here

# Get your Nano Banana API key from your Nano Banana developer dashboard:
NANOBANANA_API_KEY=your_nanobanana_api_key_here

# Override the Nano Banana base URL if the domain ever changes (optional):
# NANOBANANA_BASE_URL=https://api.nanobananaapi.dev
